[Unit]
Description=TonamiIbuki Enterprise IT AIOps Web
After=network.target tonamiibuki-api.service

[Service]
Type=simple
WorkingDirectory=/home/TonamiIbuki
ExecStart=/usr/local/bin/streamlit run /home/TonamiIbuki/ui/app.py --server.address 0.0.0.0 --server.port 8080
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
